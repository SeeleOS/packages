From b2318be254d2799ed0fb5532e3a466959cdc9df5 Mon Sep 17 00:00:00 2001
From: Codex <codex@example.com>
Date: Tue, 14 Apr 2026 14:47:59 +0800
Subject: [PATCH] Support Seele platform

---
 src/util/fy-endian.h | 2 +-
 src/util/fy-utils.c  | 9 ++++++---
 2 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/src/util/fy-endian.h b/src/util/fy-endian.h
index 0b6fa03..28da706 100644
--- a/src/util/fy-endian.h
+++ b/src/util/fy-endian.h
@@ -8,7 +8,7 @@
 #ifndef FY_ENDIAN_H
 #define FY_ENDIAN_H
 
-#if defined(__linux__) || defined(__CYGWIN__) || defined(__OpenBSD__) || defined(__GNU__) || defined(__EMSCRIPTEN__)
+#if defined(__linux__) || defined(__CYGWIN__) || defined(__OpenBSD__) || defined(__GNU__) || defined(__EMSCRIPTEN__) || defined(__seele__)
 # include <endian.h>
 #elif defined(__APPLE__)
 # include <libkern/OSByteOrder.h>
diff --git a/src/util/fy-utils.c b/src/util/fy-utils.c
index 46dcf17..74ca630 100644
--- a/src/util/fy-utils.c
+++ b/src/util/fy-utils.c
@@ -952,7 +952,10 @@ struct fy_memstream *fy_memstream_open(FILE **fpp)
 	if (!fyms)
 		return NULL;
 	memset(fyms, 0, sizeof(*fyms));
-#if !defined(_WIN32)
+#if defined(__seele__)
+	/* Seele lacks open_memstream(), so use the buffered tmpfile fallback. */
+	fyms->fp = tmpfile();
+#elif !defined(_WIN32)
 	fyms->fp = open_memstream(&fyms->buf, &fyms->size);
 #else
 	fyms->fp = tmpfile();
@@ -968,7 +971,7 @@ struct fy_memstream *fy_memstream_open(FILE **fpp)
 char *fy_memstream_close(struct fy_memstream *fyms, size_t *sizep)
 {
 	char *buf;
-#if defined(_WIN32)
+#if defined(__seele__) || defined(_WIN32)
 	long sz;
 #endif
 
@@ -977,7 +980,7 @@ char *fy_memstream_close(struct fy_memstream *fyms, size_t *sizep)
 		return NULL;
 	}
 
-#if defined(_WIN32)
+#if defined(__seele__) || defined(_WIN32)
 	if (fyms->fp && fflush(fyms->fp) == 0 &&
 	    (sz = ftell(fyms->fp)) >= 0 &&
 	    (fyms->buf = malloc((size_t)sz + 1)) != NULL) {
-- 
