 void FAST_FUNC xsettimeofday(const struct timeval *tv)
 {
+#if defined(__seele__)
+	(void) tv;
+	errno = ENOSYS;
+	bb_simple_perror_msg_and_die("settimeofday");
+#else
 	if (settimeofday(tv, NULL))
 		bb_simple_perror_msg_and_die("settimeofday");
+#endif
 }
 
 void FAST_FUNC xgettimeofday(struct timeval *tv)

