diff --git a/os/xsha1.c b/os/xsha1.c
index 859551106..7227707d4 100644
--- a/os/xsha1.c
+++ b/os/xsha1.c
@@ -257,6 +257,167 @@ x_sha1_final(void *ctx, unsigned char result[20])
     return 1;
 }
 
+#elif defined(HAVE_SHA1_IN_FALLBACK)
+
+#include <stdint.h>
+#include <string.h>
+
+typedef struct {
+    uint32_t h[5];
+    uint64_t len;
+    unsigned char block[64];
+    size_t block_len;
+} SHA1_CTX_FALLBACK;
+
+static uint32_t
+sha1_rotl(uint32_t value, unsigned bits)
+{
+    return (value << bits) | (value >> (32 - bits));
+}
+
+static uint32_t
+sha1_load_be32(const unsigned char *data)
+{
+    return ((uint32_t) data[0] << 24) |
+           ((uint32_t) data[1] << 16) |
+           ((uint32_t) data[2] << 8) |
+           (uint32_t) data[3];
+}
+
+static void
+sha1_store_be32(unsigned char *data, uint32_t value)
+{
+    data[0] = (unsigned char) (value >> 24);
+    data[1] = (unsigned char) (value >> 16);
+    data[2] = (unsigned char) (value >> 8);
+    data[3] = (unsigned char) value;
+}
+
+static void
+sha1_transform(SHA1_CTX_FALLBACK *ctx, const unsigned char block[64])
+{
+    uint32_t w[80];
+    uint32_t a = ctx->h[0];
+    uint32_t b = ctx->h[1];
+    uint32_t c = ctx->h[2];
+    uint32_t d = ctx->h[3];
+    uint32_t e = ctx->h[4];
+    int i;
+
+    for (i = 0; i < 16; i++)
+        w[i] = sha1_load_be32(block + i * 4);
+    for (i = 16; i < 80; i++)
+        w[i] = sha1_rotl(w[i - 3] ^ w[i - 8] ^ w[i - 14] ^ w[i - 16], 1);
+
+    for (i = 0; i < 80; i++) {
+        uint32_t f;
+        uint32_t k;
+        uint32_t temp;
+
+        if (i < 20) {
+            f = (b & c) | ((~b) & d);
+            k = 0x5A827999;
+        } else if (i < 40) {
+            f = b ^ c ^ d;
+            k = 0x6ED9EBA1;
+        } else if (i < 60) {
+            f = (b & c) | (b & d) | (c & d);
+            k = 0x8F1BBCDC;
+        } else {
+            f = b ^ c ^ d;
+            k = 0xCA62C1D6;
+        }
+
+        temp = sha1_rotl(a, 5) + f + e + k + w[i];
+        e = d;
+        d = c;
+        c = sha1_rotl(b, 30);
+        b = a;
+        a = temp;
+    }
+
+    ctx->h[0] += a;
+    ctx->h[1] += b;
+    ctx->h[2] += c;
+    ctx->h[3] += d;
+    ctx->h[4] += e;
+}
+
+void *
+x_sha1_init(void)
+{
+    SHA1_CTX_FALLBACK *ctx = malloc(sizeof(*ctx));
+
+    if (!ctx)
+        return NULL;
+
+    ctx->h[0] = 0x67452301;
+    ctx->h[1] = 0xEFCDAB89;
+    ctx->h[2] = 0x98BADCFE;
+    ctx->h[3] = 0x10325476;
+    ctx->h[4] = 0xC3D2E1F0;
+    ctx->len = 0;
+    ctx->block_len = 0;
+    return ctx;
+}
+
+int
+x_sha1_update(void *ctx, void *data, int size)
+{
+    SHA1_CTX_FALLBACK *sha1_ctx = ctx;
+    const unsigned char *input = data;
+    size_t remaining;
+
+    if (size < 0)
+        return 0;
+
+    sha1_ctx->len += (uint64_t) size;
+    remaining = (size_t) size;
+
+    while (remaining > 0) {
+        size_t chunk = sizeof(sha1_ctx->block) - sha1_ctx->block_len;
+        if (chunk > remaining)
+            chunk = remaining;
+
+        memcpy(sha1_ctx->block + sha1_ctx->block_len, input, chunk);
+        sha1_ctx->block_len += chunk;
+        input += chunk;
+        remaining -= chunk;
+
+        if (sha1_ctx->block_len == sizeof(sha1_ctx->block)) {
+            sha1_transform(sha1_ctx, sha1_ctx->block);
+            sha1_ctx->block_len = 0;
+        }
+    }
+
+    return 1;
+}
+
+int
+x_sha1_final(void *ctx, unsigned char result[20])
+{
+    SHA1_CTX_FALLBACK *sha1_ctx = ctx;
+    uint64_t bit_len = sha1_ctx->len * 8;
+    int i;
+
+    sha1_ctx->block[sha1_ctx->block_len++] = 0x80;
+    if (sha1_ctx->block_len > 56) {
+        while (sha1_ctx->block_len < 64)
+            sha1_ctx->block[sha1_ctx->block_len++] = 0;
+        sha1_transform(sha1_ctx, sha1_ctx->block);
+        sha1_ctx->block_len = 0;
+    }
+    while (sha1_ctx->block_len < 56)
+        sha1_ctx->block[sha1_ctx->block_len++] = 0;
+    for (i = 0; i < 8; i++)
+        sha1_ctx->block[56 + i] = (unsigned char) (bit_len >> ((7 - i) * 8));
+    sha1_transform(sha1_ctx, sha1_ctx->block);
+    for (i = 0; i < 5; i++)
+        sha1_store_be32(result + i * 4, sha1_ctx->h[i]);
+    free(sha1_ctx);
+    return 1;
+}
+
