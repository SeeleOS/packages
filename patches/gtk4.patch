diff --git a/gdk/x11/gdkdisplay-x11.c b/gdk/x11/gdkdisplay-x11.c
index b6384ae..2f1f1b5 100644
--- a/gdk/x11/gdkdisplay-x11.c
+++ b/gdk/x11/gdkdisplay-x11.c
@@ -56,7 +56,9 @@
 #include <errno.h>
 #include <unistd.h>
 
+#ifdef HAVE_EGL
 #include <epoxy/egl.h>
+#endif
 
 #include <X11/Xatom.h>
 #include <X11/Xlibint.h>
@@ -2943,6 +2945,7 @@ visual_is_rgba (XVisualInfo *visinfo)
     visinfo->visual->blue_mask  == 0x0000ff;
 }
 
+#ifdef HAVE_EGL
 static guint
 gdk_x11_display_rate_egl_config (GdkDisplay *display,
                                  gpointer    egl_display,
@@ -2969,6 +2972,7 @@ gdk_x11_display_rate_egl_config (GdkDisplay *display,
 
   return distance;
 }
+#endif
 
 static gboolean
 gdk_x11_display_init_gl_backend (GdkX11Display  *self,
@@ -2978,9 +2982,13 @@ gdk_x11_display_init_gl_backend (GdkX11Display  *self,
 {
   GdkDisplay *display = GDK_DISPLAY (self);
   Display *dpy = gdk_x11_display_get_xdisplay (GDK_DISPLAY (self));
+#ifdef HAVE_EGL
   EGLDisplay egl_display;
+#endif
   XVisualInfo *visinfo;
+#ifdef HAVE_EGL
   int visualid;
+#endif
 
   /* No env vars set, do the regular GL initialization.
    * 
@@ -2993,6 +3001,7 @@ gdk_x11_display_init_gl_backend (GdkX11Display  *self,
    * EGL, we want to avoid using it in favor of GLX.
    */
 
+#ifdef HAVE_EGL
   if (!gdk_display_init_egl (display, EGL_PLATFORM_X11_KHR, dpy, FALSE, error))
     {
       g_clear_error (error);
@@ -3025,6 +3034,9 @@ gdk_x11_display_init_gl_backend (GdkX11Display  *self,
   XFree (visinfo);
 
   return TRUE;
+#else
+  return gdk_x11_display_init_glx (self, out_visual, out_depth, error);
+#endif
 }
 
 static GdkGLContext *
@@ -3041,7 +3053,11 @@ gdk_x11_display_init_gl (GdkDisplay  *display,
   if (self->glx_config != NULL)
     return g_object_new (GDK_TYPE_X11_GL_CONTEXT_GLX, "surface", self->leader_gdk_surface, NULL);
   else if (gdk_display_get_egl_display (display))
+#ifdef HAVE_EGL
     return g_object_new (GDK_TYPE_X11_GL_CONTEXT_EGL, "surface", self->leader_gdk_surface, NULL);
+#else
+    g_return_val_if_reached (NULL);
+#endif
   else
     g_return_val_if_reached (NULL);
 }
@@ -3079,7 +3095,9 @@ G_GNUC_END_IGNORE_DEPRECATIONS
   display_class->get_keymap = gdk_x11_display_get_keymap;
 
   display_class->init_gl = gdk_x11_display_init_gl;
+#ifdef HAVE_EGL
   display_class->rate_egl_config = gdk_x11_display_rate_egl_config;
+#endif
 
   display_class->get_default_seat = gdk_x11_display_get_default_seat;
 
