From 652a675f162d2aa98627e0d7d33144e6cda007d0 Mon Sep 17 00:00:00 2001
From: codex <codex@example.invalid>
Date: Tue, 14 Apr 2026 12:42:33 +0800
Subject: [PATCH] seele: make optional deps and glib checks compatible

---
 gdk/gdkconfig.h.meson               |  3 +++
 gdk/gdkcontentdeserializer.c        |  7 ++++++-
 gdk/gdkcontentserializer.c          | 13 ++++++++++++-
 gdk/gdkdmabuf.c                     |  2 +-
 gdk/gdktexture.c                    | 23 ++++++++++++++++++++++-
 gdk/meson.build                     | 22 ++++++++++++++++++----
 gdk/wayland/gdksubsurface-wayland.c |  4 ++--
 gdk/win32/gdkdrag-win32.c           |  2 +-
 gdk/win32/gdkinput-winpointer.c     |  2 +-
 gdk/x11/gdkdisplay-x11.c            | 18 ++++++++++++++++++
 gdk/x11/meson.build                 |  5 ++++-
 gtk/deprecated/gtkshortcutsgroup.c  |  4 ++--
 gtk/gtkcssstaticstyle.c             |  2 +-
 gtk/gtkfilechooserwidget.c          |  6 +++---
 gtk/gtkfiledialog.c                 |  4 ++--
 gtk/gtkwindow.c                     |  2 +-
 gtk/inspector/general.c             | 10 +++++++---
 meson.build                         |  4 ++--
 18 files changed, 106 insertions(+), 27 deletions(-)

diff --git a/gdk/gdkconfig.h.meson b/gdk/gdkconfig.h.meson
index 17276e0..407fd6e 100644
--- a/gdk/gdkconfig.h.meson
+++ b/gdk/gdkconfig.h.meson
@@ -21,6 +21,9 @@ G_BEGIN_DECLS
 #mesondefine GDK_RENDERING_GL
 #mesondefine GDK_RENDERING_VULKAN
 
+#mesondefine GDK_HAVE_TIFF
+#mesondefine GDK_HAVE_JPEG
+
 G_END_DECLS
 
 #endif  /* __GDKCONFIG_H__ */
diff --git a/gdk/gdkcontentdeserializer.c b/gdk/gdkcontentdeserializer.c
index e367c93..f3a7a78 100644
--- a/gdk/gdkcontentdeserializer.c
+++ b/gdk/gdkcontentdeserializer.c
@@ -27,7 +27,9 @@
 #include "gdkrgbaprivate.h"
 #include "gdkprivate.h"
 #include "loaders/gdkpngprivate.h"
+#ifdef GDK_HAVE_TIFF
 #include "loaders/gdktiffprivate.h"
+#endif
 
 #include <gdk-pixbuf/gdk-pixbuf.h>
 
@@ -923,16 +925,20 @@ init (void)
                                      texture_deserializer,
                                      NULL,
                                      NULL);
+#ifdef GDK_HAVE_TIFF
   gdk_content_register_deserializer ("image/tiff",
                                      GDK_TYPE_TEXTURE,
                                      texture_deserializer,
                                      NULL,
                                      NULL);
+#endif
+#ifdef GDK_HAVE_JPEG
   gdk_content_register_deserializer ("image/jpeg",
                                      GDK_TYPE_TEXTURE,
                                      texture_deserializer,
                                      NULL,
                                      NULL);
+#endif
 
 
   formats = gdk_pixbuf_get_formats ();
@@ -1012,4 +1018,3 @@ init (void)
                                      NULL,
                                      NULL);
 }
-
diff --git a/gdk/gdkcontentserializer.c b/gdk/gdkcontentserializer.c
index 72e648c..9fc5a23 100644
--- a/gdk/gdkcontentserializer.c
+++ b/gdk/gdkcontentserializer.c
@@ -27,8 +27,12 @@
 #include "gdktextureprivate.h"
 #include "gdkrgba.h"
 #include "loaders/gdkpngprivate.h"
+#ifdef GDK_HAVE_TIFF
 #include "loaders/gdktiffprivate.h"
+#endif
+#ifdef GDK_HAVE_JPEG
 #include "loaders/gdkjpegprivate.h"
+#endif
 #include "gdkmemorytextureprivate.h"
 #include "gdkprivate.h"
 
@@ -692,10 +696,14 @@ serialize_texture_in_thread (GTask        *task,
 
   if (strcmp (gdk_content_serializer_get_mime_type (serializer), "image/png") == 0)
     bytes = gdk_save_png (texture);
+#ifdef GDK_HAVE_TIFF
   else if (strcmp (gdk_content_serializer_get_mime_type (serializer), "image/tiff") == 0)
     bytes = gdk_save_tiff (texture);
+#endif
+#ifdef GDK_HAVE_JPEG
   else if (strcmp (gdk_content_serializer_get_mime_type (serializer), "image/jpeg") == 0)
     bytes = gdk_save_jpeg (texture);
+#endif
   else
     g_assert_not_reached ();
 
@@ -983,15 +991,19 @@ init (void)
                                    texture_serializer,
                                    NULL, NULL);
 
+#ifdef GDK_HAVE_TIFF
   gdk_content_register_serializer (GDK_TYPE_TEXTURE,
                                    "image/tiff",
                                    texture_serializer,
                                    NULL, NULL);
+#endif
 
+#ifdef GDK_HAVE_JPEG
   gdk_content_register_serializer (GDK_TYPE_TEXTURE,
                                    "image/jpeg",
                                    texture_serializer,
                                    NULL, NULL);
+#endif
 
   formats = gdk_pixbuf_get_formats ();
 
@@ -1082,4 +1094,3 @@ init (void)
                                    NULL,
                                    NULL);
 }
-
diff --git a/gdk/gdkdmabuf.c b/gdk/gdkdmabuf.c
index de8d7d6..d79fa81 100644
--- a/gdk/gdkdmabuf.c
+++ b/gdk/gdkdmabuf.c
@@ -25,7 +25,7 @@
 #include "gdkdmabuftextureprivate.h"
 #include "gdkmemoryformatprivate.h"
 
-#ifdef HAVE_DMABUF
+#if defined(HAVE_DMABUF) && defined(HAVE_EGL)
 #include <sys/mman.h>
 #include <sys/ioctl.h>
 #include <linux/dma-buf.h>
diff --git a/gdk/gdktexture.c b/gdk/gdktexture.c
index 9bd36e2..7f38bdc 100644
--- a/gdk/gdktexture.c
+++ b/gdk/gdktexture.c
@@ -61,8 +61,12 @@
 #include <glib/gi18n-lib.h>
 #include <graphene.h>
 #include "loaders/gdkpngprivate.h"
+#ifdef GDK_HAVE_TIFF
 #include "loaders/gdktiffprivate.h"
+#endif
+#ifdef GDK_HAVE_JPEG
 #include "loaders/gdkjpegprivate.h"
+#endif
 
 /**
  * gdk_texture_error_quark:
@@ -645,8 +649,14 @@ gboolean
 gdk_texture_can_load (GBytes *bytes)
 {
   return gdk_is_png (bytes) ||
+#ifdef GDK_HAVE_JPEG
          gdk_is_jpeg (bytes) ||
+#endif
+#ifdef GDK_HAVE_TIFF
          gdk_is_tiff (bytes);
+#else
+         FALSE;
+#endif
 }
 
 static GdkTexture *
@@ -657,14 +667,18 @@ gdk_texture_new_from_bytes_internal (GBytes  *bytes,
     {
       return gdk_load_png (bytes, NULL, error);
     }
+#ifdef GDK_HAVE_JPEG
   else if (gdk_is_jpeg (bytes))
     {
       return gdk_load_jpeg (bytes, error);
     }
+#endif
+#ifdef GDK_HAVE_TIFF
   else if (gdk_is_tiff (bytes))
     {
       return gdk_load_tiff (bytes, error);
     }
+#endif
   else
     {
       g_set_error_literal (error,
@@ -1186,6 +1200,9 @@ gboolean
 gdk_texture_save_to_tiff (GdkTexture  *texture,
                           const char  *filename)
 {
+#ifndef GDK_HAVE_TIFF
+  return FALSE;
+#else
   GBytes *bytes;
   gboolean result;
 
@@ -1200,6 +1217,7 @@ gdk_texture_save_to_tiff (GdkTexture  *texture,
   g_bytes_unref (bytes);
 
   return result;
+#endif
 }
 
 /**
@@ -1226,8 +1244,11 @@ gdk_texture_save_to_tiff (GdkTexture  *texture,
 GBytes *
 gdk_texture_save_to_tiff_bytes (GdkTexture *texture)
 {
+#ifndef GDK_HAVE_TIFF
+  return NULL;
+#else
   g_return_val_if_fail (GDK_IS_TEXTURE (texture), NULL);
 
   return gdk_save_tiff (texture);
+#endif
 }
-
diff --git a/gdk/meson.build b/gdk/meson.build
index 5653aac..783288c 100644
--- a/gdk/meson.build
+++ b/gdk/meson.build
@@ -71,10 +71,16 @@ gdk_public_sources = files([
   'gdktoplevel.c',
   'gdkvulkancontext.c',
   'loaders/gdkpng.c',
-  'loaders/gdktiff.c',
-  'loaders/gdkjpeg.c',
 ])
 
+if tiff_dep.found()
+  gdk_public_sources += files('loaders/gdktiff.c')
+endif
+
+if jpeg_dep.found()
+  gdk_public_sources += files('loaders/gdkjpeg.c')
+endif
+
 gdk_public_headers = files([
   'gdk.h',
   'gdkapplaunchcontext.h',
@@ -192,6 +198,8 @@ gdkconfig_cdata.set('GDK_WINDOWING_MACOS', macos_enabled)
 gdkconfig_cdata.set('GDK_RENDERING_CAIRO', true)
 gdkconfig_cdata.set('GDK_RENDERING_GL', true)
 gdkconfig_cdata.set('GDK_RENDERING_VULKAN', have_vulkan)
+gdkconfig_cdata.set('GDK_HAVE_TIFF', tiff_dep.found())
+gdkconfig_cdata.set('GDK_HAVE_JPEG', jpeg_dep.found())
 
 gdkconfig = configure_file(
   input: 'gdkconfig.h.meson',
@@ -237,10 +245,16 @@ gdk_deps = [
   vulkan_dep,
   libdrm_dep,
   png_dep,
-  tiff_dep,
-  jpeg_dep,
 ]
 
+if tiff_dep.found()
+  gdk_deps += tiff_dep
+endif
+
+if jpeg_dep.found()
+  gdk_deps += jpeg_dep
+endif
+
 if profiler_enabled
   if libsysprof_capture_dep.found()
     gdk_deps += [libsysprof_capture_dep]
diff --git a/gdk/wayland/gdksubsurface-wayland.c b/gdk/wayland/gdksubsurface-wayland.c
index 82fd9e8..296af62 100644
--- a/gdk/wayland/gdksubsurface-wayland.c
+++ b/gdk/wayland/gdksubsurface-wayland.c
@@ -721,7 +721,7 @@ gdk_wayland_subsurface_attach (GdkSubsurface         *sub,
     }
   else
     {
-      if (g_set_object (&self->texture, NULL))
+      if (g_set_object (&self->texture, (gpointer) NULL))
         {
           wl_surface_attach (self->surface, NULL, 0, 0);
           needs_commit = TRUE;
@@ -785,7 +785,7 @@ gdk_wayland_subsurface_detach (GdkSubsurface *sub)
       return;
     }
 
-  g_set_object (&self->texture, NULL);
+  g_set_object (&self->texture, (gpointer) NULL);
   wl_surface_attach (self->surface, NULL, 0, 0);
   wl_surface_set_opaque_region (self->surface, self->opaque_region);
   wl_surface_commit (self->surface);
diff --git a/gdk/win32/gdkdrag-win32.c b/gdk/win32/gdkdrag-win32.c
